# LLM Provider (deepseek, openai, anthropic, zhipu)
LLM_PROVIDER=deepseek

# DeepSeek Configuration (default, cost-effective)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# Anthropic Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Zhipu ChatGLM Configuration (Chinese model)
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_MODEL=glm-4-flash            # Recommended: fast and cost-effective
# ZHIPU_MODEL=glm-4-plus             # Stronger capabilities
# ZHIPU_MODEL=glm-4-air              # Latest version

# API Settings
MAX_TOKENS=3000
TEMPERATURE=0.3
REQUEST_TIMEOUT=180        # Request timeout (seconds, increased for stability)
MAX_RETRIES=5              # Maximum retry attempts (increased for stability)

# Response Cache Settings
CACHE_RESPONSES=true
CACHE_DIR=./responses_cache

# Analysis Mode Settings
TWO_PASS_MODE=true         # Two-pass analysis (recommended, ensures global consistency)
CONCISE_MODE=true          # Concise mode: shorter comments
MAX_OUTPUT_TOKENS=1000     # Output token limit

# Keywords File (user-defined focus areas)
KEYWORDS_FILE=./keywords.txt

# File Paths (defaults relative to project root)
COMMENTS_FILE=./comments.txt
DRAFT_FILE=./draft_example/draft.tex
OUTPUT_FILE=./review.tex
TEMPLATE_FILE=./output_template/review_template.tex
